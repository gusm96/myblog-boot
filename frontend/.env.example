# 백엔드 API 주소 (서버 컴포넌트 fetch, 클라이언트 fetch 모두 사용)
# 로컬 개발
NEXT_PUBLIC_API_URL=http://localhost:8080

# Docker Compose 운영 환경 (docker-compose.yaml의 NEXT_PUBLIC_API_URL ARG로 빌드 시 주입)
# NEXT_PUBLIC_API_URL=http://backend:8080

# On-demand revalidation secret — 백엔드가 /api/revalidate 호출 시 x-revalidate-secret 헤더로 전달
# 로컬 개발: 임의 문자열로 설정. 운영: 충분한 엔트로피의 랜덤 값 사용 (예: openssl rand -hex 32)
REVALIDATE_SECRET=your-revalidate-secret-here
