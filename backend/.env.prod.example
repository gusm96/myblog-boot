# 운영 환경 환경변수 예시
# 운영 서버에서 이 파일을 복사하여 .env.prod 를 만들고 실제 값을 입력하세요.
# .env.prod 는 절대 git에 커밋하지 마세요.

PROFILE=prod
DB_URL=jdbc:mariadb://db:3306/myblog
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=
JWT_SECRET_KEY=
REDIS_HOST=rediscache
REDIS_PORT=6379
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
