# 개발 환경 환경변수 예시
# 개발 서버에서 이 파일을 복사하여 .env.dev 를 만들고 실제 값을 입력하세요.
# .env.dev 는 절대 git에 커밋하지 마세요.

#Profile
PROFILE=dev

#Database
DB_URL=jdbc:mariadb://db:3306/test
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

#Json Web Token Secret Key
JWT_SECRET_KEY=

#Redis
REDIS_HOST=rediscache
REDIS_PORT=6379

#CORS Allowed
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

#HMAC Secret
VISITOR_HMAC_SECRET=
POST_VIEW_HMAC_SECRET=
POST_LIKE_HMAC_SECRET=

#AWS
AWS_S3_BUCKET_NAME=
AWS_CREDENTIALS_ACCESS_KEY=
AWS_CREDENTIALS_SECRET_KEY=